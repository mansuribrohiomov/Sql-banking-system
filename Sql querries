--5. �	Customers who made multiple large transactions
--(above $10,000) within a short time frame (less than 1 hour apart)

with CTE as (
    select 
        c.CustomerID, 
        c.FullName, 
        t.TransactionID, 
        t.Amount, 
        t.Date 
    from Customers c
    join Accounts a on c.CustomerID = a.CustomerID
    join Transactions t on a.AccountID = t.AccountID
    where t.Amount > 10000
)
select distinct 
    c1.CustomerID, 
    c1.FullName 
from CTE c1
join CTE c2 on c1.CustomerID = c2.CustomerID 
    and c1.TransactionID < c2.TransactionID 
where DATEDIFF(SECOND, c1.Date, c2.Date) <= 3600 
  and DATEDIFF(SECOND, c1.Date, c2.Date) >= -3600;
--6.Customers who have made transactions from different countries within 
--10 minutes, a common red flag for fraud.

;with CTE1 as(
    select 
        c.CustomerID, 
        c.FullName, 
        t.TransactionID, 
        t.Date, 
        b.Country 
    from Customers c
join Accounts a on c.CustomerID = a.CustomerID
join Transactions t on a.AccountID = t.AccountID
join Branches b on a.BranchID = b.BranchID
)
select distinct 
    c1.CustomerID, 
    c1.FullName, 
    c1.Country as Country1, 
    c2.Country as Country2, 
    c1.Date as Time1, 
    c2.Date as Time2 
from CTE1 c1
join CTE1 c2 on c1.CustomerID = c2.CustomerID
    and c1.TransactionID < c2.TransactionID 
where c1.Country <> c2.Country 
    and ABS(DATEDIFF(minute, c1.Date, c2.Date)) <= 10;
