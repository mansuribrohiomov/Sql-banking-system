--10. OnlineBankingUsers table
ALTER TABLE Useraccesslogs NOCHECK CONSTRAINT fk_log_user;

DELETE FROM Onlinebankingusers;

DECLARE @Counter INT = 1;
DECLARE @MaxRows INT = 100000;

WHILE @Counter <= @MaxRows
BEGIN
    INSERT INTO Onlinebankingusers (userid, customerid, username, passwordhash, lastlogin)
    VALUES (
        @Counter,                      -- Using counter as UserID
        @Counter,                      -- Mapping 1:1 to CustomerID for simplicity
        'user_' + CAST(@Counter AS VARCHAR(10)), 
        -- Creates a shorter, safe 32-character hash
        LOWER(REPLACE(CAST(NEWID() AS VARCHAR(36)), '-', '')), 
        DATEADD(MINUTE, -@Counter, GETDATE())
    );

    SET @Counter = @Counter + 1;
END

